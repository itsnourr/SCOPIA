# LLM Provider Configuration
# You can use either OpenAI or Google Gemini (OpenAI takes priority if both are set)

# OpenAI API Key (recommended for demos - higher rate limits)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model Name (optional, default: gpt-4o-mini)
# Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API Key (alternative)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Name (optional, default: gemini-1.5-flash)
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash
GEMINI_MODEL=gemini-1.5-flash

# PostgreSQL Database Connection
# Format: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=postgresql+psycopg2://forensic_user:password@localhost:5432/forensic_db

# AES-256-CBC Encryption Key (32 bytes = 64 hex characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AES_MASTER_KEY=your_64_character_hex_key_here

# File Storage Directories (optional, defaults shown)
FILES_DIR=./data/encrypted
CHROMA_DIR=./data/chroma

# Application Settings (optional, defaults shown)
STREAMLIT_PORT=8501
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=100

# Ethical Guardrails (optional, defaults shown)
MIN_CONFIDENCE_THRESHOLD=0.65
ENABLE_ETHICAL_GUARDRAILS=true

# LangChain Settings (optional, defaults shown)
LANGCHAIN_VERBOSE=false
LANGCHAIN_TEMPERATURE=0.1

# ChromaDB Settings (optional, defaults shown)
CHROMA_COLLECTION_NAME=forensic_evidence

